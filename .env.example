# Environment variables for vibe-coding-template
#
# Copy this file to .env and fill in values.
# Lines marked "# required" will cause deploy-check to fail if missing.
# Lines marked "# optional" are not enforced.
#
# Usage:
#   cp .env.example .env

# optional — Base URL for the web app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# optional — Example secret key placeholder
API_SECRET=
